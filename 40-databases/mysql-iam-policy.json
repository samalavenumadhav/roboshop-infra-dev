resource "aws_iam_role_policy" "mysql_ssm_policy" {
  name = "mysql-ssm-policy"
  role = aws_iam_role.mysql.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ssm:GetParameter"
        ]
        Resource = "arn:aws:ssm:us-east-1:*:parameter/roboshop/*"
      }
    ]
  })
}